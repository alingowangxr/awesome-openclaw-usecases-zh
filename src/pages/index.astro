---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import UsecaseCard from '../components/UsecaseCard.astro';

const allUsecases = await getCollection('usecases');
const featuredUsecases = allUsecases.filter(u => u.data.featured);

const categories = [
  { name: '中國特色', icon: '🇨🇳', color: 'red' },
  { name: '社群媒體', icon: '📱', color: 'blue' },
  { name: '創意與構建', icon: '🎨', color: 'purple' },
  { name: '基礎設施與DevOps', icon: '⚙️', color: 'orange' },
  { name: '生產力', icon: '⚡', color: 'green' },
  { name: '研究與學習', icon: '🔬', color: 'teal' },
  { name: '金融與交易', icon: '📈', color: 'yellow' },
];

const categoryCounts = Object.fromEntries(
  categories.map(c => [c.name, allUsecases.filter(u => u.data.category === c.name).length])
);

const categoryCardClasses: Record<string, { border: string; bg: string; icon: string; count: string; link: string }> = {
  red:    { border: 'border-red-200',    bg: 'bg-red-50',    icon: 'bg-red-100',    count: 'text-red-600',    link: 'text-red-600 hover:text-red-700' },
  blue:   { border: 'border-blue-200',   bg: 'bg-blue-50',   icon: 'bg-blue-100',   count: 'text-blue-600',   link: 'text-blue-600 hover:text-blue-700' },
  purple: { border: 'border-purple-200', bg: 'bg-purple-50', icon: 'bg-purple-100', count: 'text-purple-600', link: 'text-purple-600 hover:text-purple-700' },
  orange: { border: 'border-orange-200', bg: 'bg-orange-50', icon: 'bg-orange-100', count: 'text-orange-600', link: 'text-orange-600 hover:text-orange-700' },
  green:  { border: 'border-green-200',  bg: 'bg-green-50',  icon: 'bg-green-100',  count: 'text-green-600',  link: 'text-green-600 hover:text-green-700' },
  teal:   { border: 'border-teal-200',   bg: 'bg-teal-50',   icon: 'bg-teal-100',   count: 'text-teal-600',   link: 'text-teal-600 hover:text-teal-700' },
  yellow: { border: 'border-yellow-200', bg: 'bg-yellow-50', icon: 'bg-yellow-100', count: 'text-yellow-600', link: 'text-yellow-600 hover:text-yellow-700' },
};
---

<Layout title="首頁" description="OpenClaw AI 智能體最佳用例合集，40 個經過驗證的真實場景，手把手教你用 AI 智能體自動化工作與生活。">
  <!-- Hero 區塊 -->
  <section class="bg-gradient-to-b from-indigo-50 to-white py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 bg-indigo-100 text-indigo-700 text-sm font-medium px-4 py-1.5 rounded-full mb-6">
        <span>🦀</span>
        <span>Awesome OpenClaw 用例合集（中文版）</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-6 leading-tight">
        OpenClaw AI 智能體<br class="hidden sm:block" />最佳用例合集
      </h1>
      <p class="text-lg sm:text-xl text-gray-600 mb-10 max-w-2xl mx-auto leading-relaxed">
        40 個經過驗證的真實場景，手把手教你用 AI 智能體自動化工作與生活
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/usecases"
          class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-6 py-3 rounded-lg transition-colors shadow-sm"
        >
          瀏覽全部用例 →
        </a>
        <a
          href="/contributing"
          class="inline-flex items-center gap-2 bg-white hover:bg-gray-50 text-gray-700 font-semibold px-6 py-3 rounded-lg border border-gray-300 transition-colors"
        >
          查看貢獻指南
        </a>
      </div>
    </div>
  </section>

  <!-- 統計數字區塊 -->
  <section class="py-12 px-4 bg-white border-y border-gray-100">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-3 gap-8 text-center">
        <div>
          <p class="text-4xl font-bold text-indigo-600 mb-1">40+</p>
          <p class="text-sm text-gray-500 font-medium">個用例</p>
        </div>
        <div>
          <p class="text-4xl font-bold text-indigo-600 mb-1">7</p>
          <p class="text-sm text-gray-500 font-medium">大分類</p>
        </div>
        <div>
          <p class="text-4xl font-bold text-indigo-600 mb-1">3</p>
          <p class="text-sm text-gray-500 font-medium">種難度</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 7 大分類卡片 -->
  <section class="py-16 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">7 大場景分類</h2>
        <p class="text-gray-500">找到最適合你的使用場景</p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {categories.map(cat => {
          const c = categoryCardClasses[cat.color];
          const count = categoryCounts[cat.name] ?? 0;
          return (
            <a
              href={`/usecases?category=${encodeURIComponent(cat.name)}`}
              class={`flex flex-col items-start p-5 rounded-xl border ${c.border} ${c.bg} hover:shadow-md transition-all duration-200 group`}
            >
              <div class={`w-10 h-10 rounded-lg ${c.icon} flex items-center justify-center text-xl mb-3`}>
                {cat.icon}
              </div>
              <h3 class="font-semibold text-gray-900 text-sm mb-1 group-hover:text-indigo-600 transition-colors">
                {cat.name}
              </h3>
              <p class={`text-xs font-medium ${c.count}`}>{count} 個用例</p>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- 精選用例 -->
  {featuredUsecases.length > 0 && (
    <section class="py-16 px-4 bg-white border-t border-gray-100">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-10">
          <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">精選用例</h2>
          <p class="text-gray-500">編輯嚴選，最具代表性的使用場景</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {featuredUsecases.map(u => (
            <UsecaseCard
              id={u.id}
              title={u.data.title}
              description={u.data.description}
              category={u.data.category}
              difficulty={u.data.difficulty}
              tags={u.data.tags}
            />
          ))}
        </div>
        <div class="text-center mt-10">
          <a
            href="/usecases"
            class="inline-flex items-center gap-2 text-indigo-600 hover:text-indigo-700 font-medium text-sm"
          >
            查看全部 {allUsecases.length} 個用例 →
          </a>
        </div>
      </div>
    </section>
  )}
</Layout>
