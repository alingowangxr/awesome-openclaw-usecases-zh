---
interface Props {
  category: string;
}

const { category } = Astro.props;

const categoryColors: Record<string, string> = {
  '中國特色': 'bg-red-100 text-red-700 border border-red-200',
  '社群媒體': 'bg-blue-100 text-blue-700 border border-blue-200',
  '創意與構建': 'bg-purple-100 text-purple-700 border border-purple-200',
  '基礎設施與DevOps': 'bg-orange-100 text-orange-700 border border-orange-200',
  '生產力': 'bg-green-100 text-green-700 border border-green-200',
  '研究與學習': 'bg-teal-100 text-teal-700 border border-teal-200',
  '金融與交易': 'bg-yellow-100 text-yellow-700 border border-yellow-200',
};

const classes = categoryColors[category] ?? 'bg-gray-100 text-gray-700 border border-gray-200';
---

<span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${classes}`}>
  {category}
</span>
